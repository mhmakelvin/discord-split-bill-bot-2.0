{
  "name": "discord-split-bill-bot-2.0",
  "version": "1.0.0",
  "description": "A split bill bot designed for Discord",
  "main": "src/app.ts",
  "type": "module",
  "scripts": {
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:push": "npx drizzle-kit push",
    "format": "npx prettier --write . '!src/db/db'",
    "start": "npx tsx -r dotenv/config src/app.ts"
  },
