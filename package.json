  },
  "homepage": "https://github.com/mhmakelvin/discord-split-bill-bot-2.0#readme",
  "dependencies": {
    "@types/node": "^25.3.0",
    "discord.js": "^14.25.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.8",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.3",
